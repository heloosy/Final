{
  "version": 2,
  "functions": {
    "api/index.js": {
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/voice/(.*)", "destination": "/api/index.js" },
    { "source": "/whatsapp/(.*)", "destination": "/api/index.js" },
    { "source": "/", "destination": "/api/index.js" }
  ]
}
